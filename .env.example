# NoCap Environment Variables
# Copy this file to .env.local and fill in your values.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── VirusTotal ────────────────────────────────────────────────────────────────
# Free API key: https://www.virustotal.com/gui/sign-in (then My API Key)
VIRUSTOTAL_API_KEY=your-virustotal-api-key

# ── AbuseIPDB ─────────────────────────────────────────────────────────────────
# Free API key: https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=your-abuseipdb-api-key

# ── GitHub Search ─────────────────────────────────────────────────────────────
# Free PAT: https://github.com/settings/tokens (needs public_repo scope)
GITHUB_API_TOKEN=your-github-personal-access-token

